# ── Required ──────────────────────────────────────────────────────────────────

# Public base URL of this SSF transmitter (used as JWT iss claim).
# Recommended: set to the same value as SSF_BASE_URL.
# If set to an Authentik OIDC application URL, a warning is logged at startup.
SSF_ISSUER=https://idp.example.com/shared-signals

# Public base URL under which this service is reachable by SSF receivers
SSF_BASE_URL=https://idp.example.com/shared-signals

# Bearer token protecting all /ssf/* management endpoints (min 32 chars)
# Required. Generate with: openssl rand -hex 32
SSF_MANAGEMENT_TOKEN=change_me_to_random_string_min_32_chars

# ── Webhook authentication ────────────────────────────────────────────────────

# Webhook auth mode: bearer (default/recommended), hmac, unsigned
# bearer  — Authentik sends Authorization: Bearer <SSF_WEBHOOK_TOKEN> via Header Mapping
# hmac    — Authentik sends X-Authentik-Signature (legacy)
# unsigned — no auth (dev/lab only)
SSF_WEBHOOK_AUTH_MODE=bearer

# Token for bearer mode — set in Authentik Webhook Header Mapping (min 32 chars)
# Do NOT reuse SSF_MANAGEMENT_TOKEN here; keep them separate.
# Generate with: openssl rand -hex 32
SSF_WEBHOOK_TOKEN=change_me_to_random_string_min_32_chars

# Legacy HMAC secret — only required when SSF_WEBHOOK_AUTH_MODE=hmac
# SSF_WEBHOOK_SECRET=change_me_to_random_string_min_32_chars

# ── Optional ──────────────────────────────────────────────────────────────────

# URL path prefix when running behind a reverse proxy sub-path (default: empty)
SSF_ROOT_PATH=/shared-signals

# Host port exposed by Docker (default: 62107)
SSF_HOST_PORT=62107

# Port the container listens on internally (default: 8000)
SSF_CONTAINER_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
SSF_LOG_LEVEL=INFO

# Enable ANSI-coloured log output — Portainer renders ANSI escape codes.
# Requires the colorlog package (included in requirements.txt).
# SSF_LOG_COLOR=false

# Path to the SQLite database file inside the container (default: /app/data/ssf.db)
# SSF_DATABASE_PATH=/app/data/ssf.db

# Directory where the RS256 private key and JWKS are stored (default: /app/keys)
# SSF_KEYS_DIR=/app/keys

# ── Apple SCIM directory sync (optional) ──────────────────────────────────────
# When all four required fields below are set, the service will automatically
# sync users from Authentik to Apple Business Manager once per hour.
# Leave unset to disable SCIM sync entirely (SSF/CAEP features still work).

# Client ID and secret generated by ABM under Settings → Directory Sync.
# The secret expires every 6/9/12 months; generate a new one in ABM and update here.
# APPLE_SCIM_CLIENT_ID=SCIM.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APPLE_SCIM_CLIENT_SECRET=

# Base URL and API token for your Authentik instance.
# Create the token in Authentik: Admin → Directory → Tokens → Create (type: API).
# AUTHENTIK_URL=https://idp.example.com
# AUTHENTIK_TOKEN=

# (Optional) Authentik group UUID — sync only members of this group.
# Leave unset to sync all active internal users.
# APPLE_SCIM_GROUP_ID=

# Seconds between automatic syncs (default: 3600 = 1 hour)
# APPLE_SCIM_SYNC_INTERVAL=3600

# ── Security (optional) ───────────────────────────────────────────────────────

# DEPRECATED — use SSF_WEBHOOK_AUTH_MODE=unsigned instead.
# Will be removed in a future release. Setting this to true logs a startup warning.
# SSF_ALLOW_UNSIGNED_WEBHOOK=false

# HMAC key for email pseudonymisation in logs (optional, recommended in production).
# Falls back to SSF_MANAGEMENT_TOKEN when unset.
# Generate with: openssl rand -hex 32
# SSF_PII_PEPPER=

# Comma-separated list of allowed receiver hostnames for SSRF protection.
# If set, endpoint_url host must exactly match one of these.
# Leave unset to allow any public host (private IPs are always blocked).
# SSF_ALLOWED_RECEIVER_HOSTS=receiver.example.com,backup-receiver.example.com
